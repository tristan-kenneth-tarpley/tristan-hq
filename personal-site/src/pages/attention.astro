---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import AttentionLab from "../components/lab/AttentionLab.tsx";
---

<BaseLayout
  title="Attention Lab"
  description="Interactive visualizers for the attention mechanisms behind modern LLMs."
>
  <div
    class="min-h-screen text-white selection:bg-[#00f2ff]/30 font-sans"
  >
    {/* Background glow */}
    <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
      <div
        class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-[#00f2ff]/5 blur-[150px] rounded-full"
      >
      </div>
      <div
        class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-[#ff00e5]/5 blur-[150px] rounded-full"
      >
      </div>
    </div>

    <SiteNav back={{ label: "Back to Base", href: "/" }} />

    <AttentionLab client:load />
  </div>
</BaseLayout>
