---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Profile from "../components/Profile.astro";
import LabExperiments from "../components/LabExperiments.astro";
import { Sparkles, Radio } from "@lucide/astro";
---

<BaseLayout description="Home of tinkerings, musings, and happenings.">
  <div
    class="min-h-screen text-[#f0f9ff] selection:bg-[#00f2ff]/30 font-sans relative"
  >
    {/* Space-age background */}
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div
        class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] border-[40px] border-[#00f2ff]/5 rounded-full animate-fade-in"
        style="transform: rotate(30deg);"
      >
      </div>
      <div
        class="absolute bottom-[-5%] left-[-5%] w-[400px] h-[400px] border-[20px] border-[#ff00e5]/5 rounded-full animate-fade-in"
        style="transform: rotate(-15deg); animation-delay: 0.3s;"
      >
      </div>

      <div class="absolute top-[20%] left-[10%] text-[#00f2ff] opacity-20 animate-pulse">
        <Sparkles size={40} />
      </div>
      <div
        class="absolute bottom-[30%] right-[15%] text-[#ff00e5] opacity-20 animate-pulse"
        style="animation-delay: 0.7s;"
      >
        <Sparkles size={32} />
      </div>
    </div>

    <main
      class="max-w-5xl mx-auto px-6 py-24 flex flex-col items-center justify-center min-h-screen relative z-10"
    >
      <div class="w-full max-w-2xl text-center animate-fade-in-up">
        {/* Floating pod header */}
        <div class="relative mb-16">
          <div
            class="bg-white/10 backdrop-blur-xl border-4 border-white/20 rounded-[4rem] p-12 shadow-[0_0_50px_rgba(0,242,255,0.15)] relative z-10 transform-gpu animate-float-y"
          >
            {/* Retro antenna */}
            <div
              class="absolute -top-12 left-1/2 -translate-x-1/2 flex flex-col items-center"
            >
              <div class="w-1 h-12 bg-white/20"></div>
              <div
                class="w-4 h-4 bg-[#00f2ff] rounded-full shadow-[0_0_15px_#00f2ff] animate-pulse-glow"
              >
              </div>
            </div>

            <div
              class="inline-flex items-center gap-2 mb-6 px-4 py-1 bg-[#00f2ff]/10 border border-[#00f2ff]/30 rounded-full"
            >
              <Radio size={12} class="text-[#00f2ff] animate-pulse" />
              <span
                class="text-[10px] font-black uppercase tracking-[0.4em] text-[#00f2ff]"
              >
                Houston, Texas
              </span>
            </div>

            <h1
              class="text-7xl font-black tracking-tighter text-white mb-6 bg-gradient-to-b from-white to-[#00f2ff] bg-clip-text text-transparent italic"
            >
              Welcome to Tristan HQ
            </h1>

            <p
              class="text-xl text-blue-100/70 leading-relaxed max-w-lg mx-auto font-medium italic"
            >
              Home of tinkerings, musings, and happenings
            </p>

            {/* Jetson stilts */}
            <div
              class="absolute top-[100%] left-1/4 w-1 h-32 bg-gradient-to-b from-white/20 to-transparent -z-10"
            >
            </div>
            <div
              class="absolute top-[100%] right-1/4 w-1 h-32 bg-gradient-to-b from-white/20 to-transparent -z-10"
            >
            </div>
          </div>
        </div>

        <Profile />
        <LabExperiments />
      </div>
      <Footer />
    </main>
  </div>
</BaseLayout>
