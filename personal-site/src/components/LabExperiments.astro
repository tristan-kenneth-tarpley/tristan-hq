---
import { ArrowRight, Rocket, BookOpen } from "@lucide/astro";

const cards = [
  {
    href: "/attention",
    title: "Attention Lab",
    subtitle: "Visualizing LLM attention mechanisms",
    color: "#00f2ff",
    icon: Rocket,
    phEvent: "attention_lab",
  },
  {
    href: "/essays",
    title: "Stuff I Wrote",
    subtitle: "Essays and musings",
    color: "#ff00e5",
    icon: BookOpen,
    phEvent: "essays",
  },
] as const;
---

<section class="space-y-8 relative">
  <div class="flex items-center justify-center gap-4">
    <div class="w-3 h-3 bg-[#00f2ff] rounded-full shadow-[0_0_10px_#00f2ff]"></div>
    <h2 class="text-xs font-black uppercase tracking-[0.5em] text-[#00f2ff]">
      Lab Experiments
    </h2>
    <div class="w-3 h-3 bg-[#00f2ff] rounded-full shadow-[0_0_10px_#00f2ff]"></div>
  </div>

  <div class="grid grid-cols-1 gap-6 w-full max-w-md mx-auto">
    {
      cards.map(({ href, title, subtitle, color, icon: Icon, phEvent }) => (
        <a
          href={href}
          data-ph-event="lab_experiment_clicked"
          data-ph-experiment={phEvent}
          class="group relative block"
        >
          <div
            class="absolute inset-0 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity rounded-full"
            style={`background-color: ${color}33;`}
          />
          <div
            class="bg-[#16164d]/80 backdrop-blur-md p-8 rounded-[2.5rem] border-2 border-white/10 transition-all duration-300 flex items-center justify-between shadow-2xl relative z-10 group-hover:-translate-y-2 group-hover:scale-105"
            style={`--accent: ${color};`}
            data-accent-border
          >
            <div class="flex items-center gap-5">
              <div
                class="w-14 h-14 rounded-full flex items-center justify-center border transition-all"
                style={`background-color: ${color}1a; color: ${color}; border-color: ${color}33;`}
              >
                <Icon size={28} />
              </div>
              <div class="text-left">
                <h2 class="text-2xl font-black italic tracking-tight text-white">
                  {title}
                </h2>
                <p class="text-blue-300/50 text-[10px] uppercase font-black tracking-widest mt-1">
                  {subtitle}
                </p>
              </div>
            </div>
            <ArrowRight
              class="text-white/20 group-hover:translate-x-2 transition-all"
              size={28}
              style={`--hover-color: ${color};`}
            />
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  a.group:hover [data-accent-border] {
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  a.group:hover svg {
    color: var(--hover-color);
  }
</style>
